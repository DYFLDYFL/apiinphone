{
  "name": "apiinphone",
  "version": "1.1.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "android:debug": "npm run cap:sync && cd android && .\\gradlew.bat assembleDebug",
    "android:release": "npm run cap:sync && cd android && .\\gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/filesystem": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sandpy": "^0.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
